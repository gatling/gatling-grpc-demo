{
  "name": "gatling-ts-demo",
  "version": "1.0.0-SNAPSHOT",
  "private": true,
  "main": "target/bundle",
  "dependencies": {
    "@gatling.io/core": "3.15.103",
    "@gatling.io/grpc": "3.15.103",
    "@gatling.io/http": "3.15.103"
  },
  "devDependencies": {
    "@gatling.io/cli": "3.15.103",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "typescript": "7.0.2"
  },
  "scripts": {
    "clean": "rimraf target",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && gatling build --typescript",
    "recorder": "gatling recorder --typescript"
  }
}
